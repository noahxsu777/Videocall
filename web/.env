# .env
VITE_APP_TITLE=TUILive
VITE_RUNTIME_ENV=browser

# Tencent Cloud TRTC credentials (get them at https://console.cloud.tencent.com/trtc).
# Leave empty/0 here and override with your real values in a local .env.local file
# (git-ignored) for development, or in your hosting provider's Environment Variables
# settings (e.g. Vercel) for deploys. Never commit real values to this file.
VITE_TENCENT_SDK_APP_ID=0
VITE_TENCENT_SDK_SECRET_KEY=

# Supabase — real user accounts (register / login / session).
# Create a free project at https://supabase.com, then copy from
# Project Settings → API: Project URL and the anon/public key.
# Override with real values in .env.local (local) or your host's
# Environment Variables (Vercel). Never commit real values here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push (incoming-call notifications while the app is closed/backgrounded).
# The PUBLIC key is safe in client code — it's the whole point of VAPID.
# The PRIVATE key + Supabase service role key are SERVER-ONLY: set them
# in Vercel's Environment Variables WITHOUT the VITE_ prefix so they're
# never bundled into client JS. See web/api/notify-call.ts.
VITE_VAPID_PUBLIC_KEY=
# Server-only (no VITE_ prefix): VAPID_PRIVATE_KEY, VAPID_SUBJECT,
# SUPABASE_SERVICE_ROLE_KEY
